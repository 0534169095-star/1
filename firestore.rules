rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function initialSuperAdmin() {
      return signedIn() && (
        request.auth.uid == 'u16HUOqIP7hhUC2Wxbejpb9jWao2' ||
        (request.auth.token.email_verified == true &&
         request.auth.token.email == '0534169095@xn--4dbjbascrao3i.com')
      );
    }

    function profilePath() {
      return /databases/$(database)/documents/artifacts/org-gallery/public/data/userProfiles/$(request.auth.uid);
    }

    function hasProfile() {
      return signedIn() && exists(profilePath());
    }

    function approved() {
      return initialSuperAdmin() || (hasProfile() && get(profilePath()).data.status == 'approved');
    }

    function roleIs(role) {
      return approved() && (initialSuperAdmin() || get(profilePath()).data.role == role);
    }

    function admin() {
      return initialSuperAdmin() || roleIs('admin') || roleIs('super_admin');
    }

    function superAdmin() {
      return initialSuperAdmin() || roleIs('super_admin');
    }

    match /artifacts/org-gallery/public/data/userProfiles/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || admin());

      allow create: if signedIn() && request.auth.uid == uid && (
        (initialSuperAdmin() && request.resource.data.status == 'approved' && request.resource.data.role == 'super_admin') ||
        (request.resource.data.status == 'pending' && request.resource.data.role == 'viewer')
      );

      allow update: if admin() || (
        signedIn() && request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid', 'displayName', 'email', 'photoURL', 'lastLoginAt', 'requestDetails', 'messages'
        ])
      );

      allow delete: if superAdmin() && request.auth.uid != uid;
    }

    match /artifacts/org-gallery/public/data/folders/{folderId} {
      allow read: if approved();
      allow create, update: if admin();
      allow delete: if superAdmin();
    }

    match /artifacts/org-gallery/public/data/images/{imageId} {
      allow read: if approved();
      allow create, update: if roleIs('uploader') || admin();
      allow delete: if superAdmin();
    }

    match /artifacts/org-gallery/public/data/pendingImages/{imageId} {
      allow read: if admin();
      allow create: if roleIs('viewer') &&
        request.resource.data.status == 'pending' &&
        request.resource.data.uploadedBy == request.auth.uid;
      allow update: if admin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'approvedAt', 'approvedBy'
        ]);
      allow delete: if superAdmin();
    }

    match /artifacts/org-gallery/public/data/deletionRequests/{requestId} {
      allow create: if roleIs('admin') &&
        request.resource.data.status == 'pending' &&
        request.resource.data.requestedBy == request.auth.uid;
      allow read: if superAdmin() || (roleIs('admin') && resource.data.requestedBy == request.auth.uid);
      allow update: if superAdmin();
      allow delete: if false;
    }

    match /artifacts/org-gallery/public/data/broadcasts/{broadcastId} {
      allow read: if approved();
      allow create, update, delete: if superAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
